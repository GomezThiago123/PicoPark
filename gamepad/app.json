{
  "expo": {
    "name": "PicoPark Gamepad",
    "slug": "picopark-gamepad",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.picopark.gamepad"
    },
    "plugins": [
      "expo-keep-awake",
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "La app necesita la cámara para escanear el código QR del juego."
        }
      ]
    ]
  }
}
